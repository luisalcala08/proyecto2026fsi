                                 />

        <addForeignKeyConstraint baseColumnNames="empleado_id"
                                 baseTableName="trabajo"
                                 constraintName="fk_trabajo__empleado_id"
                                 referencedColumnNames="id"
                                 referencedTableName="empleado"
                                 />
    </changeSet>
</databaseChangeLog>
